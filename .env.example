# PM Opportunity Agent — Environment Configuration
# Copy this file to .env and fill in real values before running the application.
# Never commit .env to version control.

# Gemini API key for job evaluation
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat ID where notifications will be sent
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Google Sheets spreadsheet ID for job export
GOOGLE_SHEETS_ID=your-google-sheets-spreadsheet-id-here

# Path to the SQLite database file (default: data/jobs.db)
SQLITE_DATABASE_PATH=data/jobs.db

# Minimum match score (0-100) required for a job to generate a notification (default: 75)
JOB_MATCH_THRESHOLD=75
